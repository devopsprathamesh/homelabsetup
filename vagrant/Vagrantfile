# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# HA Kubernetes lab: 1 LB/server, 3 masters, 3 worker nodes.
# `vagrant up` brings up everything; `vagrant up <name>` brings up one node.

BOX = "cloud-image/ubuntu-24.04"

NODES = [
  { name: "server",  ip: "192.168.56.10", cpus: 1, memory: 1024 },
  { name: "master1", ip: "192.168.56.11", cpus: 2, memory: 2048 },
  { name: "master2", ip: "192.168.56.12", cpus: 2, memory: 2048 },
  { name: "master3", ip: "192.168.56.16", cpus: 2, memory: 2048 },
  { name: "node1",   ip: "192.168.56.13", cpus: 1, memory: 2048 },
  { name: "node2",   ip: "192.168.56.14", cpus: 1, memory: 2048 },
  { name: "node3",   ip: "192.168.56.15", cpus: 1, memory: 2048 },
]

# /etc/hosts entries shared by every node so they can reach each other by name.
HOSTS_ENTRIES = NODES.map { |n| "#{n[:ip]} #{n[:name]}" }.join("\n")
NODE_NAMES = NODES.map { |n| n[:name] }.join(" ")

# Shared keypair so `server` can SSH into every node as `admin` without a
# password. Generated once on the host and reused across `vagrant up` runs;
# never committed (see .gitignore).
require "fileutils"
KEY_DIR = File.join(__dir__, "keys")
PRIVATE_KEY_PATH = File.join(KEY_DIR, "lab_admin_ed25519")
PUBLIC_KEY_PATH = "#{PRIVATE_KEY_PATH}.pub"

unless File.exist?(PRIVATE_KEY_PATH)
  FileUtils.mkdir_p(KEY_DIR)
  system("ssh-keygen", "-t", "ed25519", "-f", PRIVATE_KEY_PATH, "-N", "", "-C", "lab-admin", "-q")
end
LAB_ADMIN_PUBKEY = File.read(PUBLIC_KEY_PATH).strip

# The host desktop's own key, so you can `ssh admin@<node>` directly from
# this machine too, not just from `server`.
HOST_PUBKEY_PATH = File.expand_path("~/.ssh/id_ed25519.pub")
HOST_ADMIN_PUBKEY = File.exist?(HOST_PUBKEY_PATH) ? File.read(HOST_PUBKEY_PATH).strip : nil

Vagrant.configure("2") do |config|
  config.vm.box = BOX
  config.vm.box_check_update = false

  NODES.each do |node|
    config.vm.define node[:name] do |machine|
      machine.vm.hostname = node[:name]
      machine.vm.network "private_network", ip: node[:ip]
      machine.disksize.size = "30GB"

      machine.vm.provider "virtualbox" do |vb|
        vb.name = node[:name]
        vb.cpus = node[:cpus]
        vb.memory = node[:memory]
        vb.gui = false
      end

      machine.vm.provision "shell",
        path: "scripts/provision-common.sh",
        env: {
          "HOSTS_ENTRIES" => HOSTS_ENTRIES,
          "LAB_ADMIN_PUBKEY" => LAB_ADMIN_PUBKEY,
          "HOST_ADMIN_PUBKEY" => HOST_ADMIN_PUBKEY.to_s,
        }

      if node[:name] == "server"
        machine.vm.provision "file",
          source: PRIVATE_KEY_PATH,
          destination: "/tmp/lab_admin_ed25519"

        machine.vm.provision "shell",
          path: "scripts/provision-server.sh",
          env: { "NODE_NAMES" => NODE_NAMES }
      end
    end
  end
end
